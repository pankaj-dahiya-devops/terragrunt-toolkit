#!/usr/bin/env python3
"""
Terragrunt Unlock All - Find and remove stale Terraform state locks.

Works exactly like terragrunt_plan_all: run it from anywhere inside your
project. It finds providers, runs terragrunt in each one, and lets terragrunt
read its own backend config. No SDK. No backend configuration needed.

Usage:
    terragrunt_unlock_all [OPTIONS] [TICKET|PATH]

Examples:
    terragrunt_unlock_all                  Check all providers for locks
    terragrunt_unlock_all AH-1             Check only providers in ticket AH-1
    terragrunt_unlock_all --dry-run        Show locks without unlocking
    terragrunt_unlock_all -u all           Show locks for all users
    terragrunt_unlock_all AH-1 --confirm   Unlock AH-1 providers without prompt
"""

import os
import sys
import argparse
from pathlib import Path
from typing import Optional, List

# =============================================================================
# PATH SETUP
# =============================================================================

script_dir = Path(__file__).parent.resolve()
sys.path.insert(0, str(script_dir))

# =============================================================================
# LOCAL IMPORTS
# =============================================================================

from lib.common import debug, error, set_verbose
from lib.project import TerraformProject
from lib.unlock_all import run_unlock, find_locks, providers_from_ticket


# =============================================================================
# ARGUMENT PARSING
# =============================================================================

def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Find and remove stale Terraform state locks",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  %(prog)s                   Check all providers for locks (your locks only)
  %(prog)s AH-1              Check only providers that were planned in AH-1
  %(prog)s --dry-run         Show locks without unlocking anything
  %(prog)s -u all            Show locks from all users
  %(prog)s AH-1 --force      Unlock AH-1 providers, skip confirmation prompt
        """,
    )

    parser.add_argument(
        "args",
        nargs="*",
        metavar="TICKET/PATH",
        help="Ticket (e.g. AH-1) or provider path to scope the check",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show locks but do not unlock anything",
    )
    parser.add_argument(
        "--force",
        action="store_true",
        help="Skip confirmation prompt and unlock immediately",
    )
    parser.add_argument(
        "-j", "--concurrency",
        type=int,
        default=int(os.environ.get("CONCURRENCY", 5)),
        metavar="N",
        help="Parallel workers for checking and unlocking (default: %(default)s)",
    )
    parser.add_argument(
        "--verbose",
        action="store_true",
        help="Enable verbose output",
    )

    return parser.parse_args()


# =============================================================================
# MAIN
# =============================================================================

def main() -> int:
    args = parse_args()

    if args.verbose:
        set_verbose(True)

    # -------------------------------------------------------------------------
    # Detect project root — same as terragrunt_plan_all
    # -------------------------------------------------------------------------
    try:
        project = TerraformProject()
    except RuntimeError as e:
        error(str(e))
        return 1

    from lib.common import info
    info(f"Project: {project.name}  ({project.root})")

    # -------------------------------------------------------------------------
    # Parse positional args — ticket or provider path (same as plan_all)
    # -------------------------------------------------------------------------
    ticket: Optional[str]     = None
    provider_paths: List[str] = []

    for arg in args.args:
        arg_type, paths = project.parse_argument(arg)
        if arg_type == "ticket":
            ticket = paths[0]
        elif arg_type == "provider":
            provider_paths.extend(paths)
        elif arg_type == "module":
            error(f"'{arg}' is a module path. Pass a ticket or provider path.")
            return 2
        else:
            error(f"'{arg}' is not a recognised ticket or provider path")
            return 2

    # Auto-detect ticket from git branch (same as plan_all)
    if ticket is None:
        branch = project.current_git_branch()
        if project.ticket_regex.match(branch):
            debug(f"Using ticket {branch} from git branch")
            ticket = branch

    # -------------------------------------------------------------------------
    # Determine which providers to check and discover locks
    # -------------------------------------------------------------------------
    import os as _os
    _os.chdir(project.root)

    if provider_paths:
        # Explicit provider paths given
        provider_dirs = [project.root / p for p in provider_paths]
        info(f"Checking {len(provider_dirs)} specified provider(s)")
        locks = find_locks(provider_dirs, project, args.concurrency)

    elif ticket:
        # Ticket given — scope to providers that were part of that plan
        provider_dirs = providers_from_ticket(ticket, project)
        if not provider_dirs:
            error(
                f"No providers found for ticket '{ticket}'.\n"
                f"Expected plan output at: tickets/{ticket}/providers/"
            )
            return 1
        info(f"Ticket:  {ticket}  ({len(provider_dirs)} provider(s))")
        locks = find_locks(provider_dirs, project, args.concurrency)

    else:
        error(f"Ticket required. Run on a ticket branch or pass a ticket/provider path.\nExample: terragrunt_unlock_all {project.jira}-1234")
        return 2

    # -------------------------------------------------------------------------
    # Display, confirm, and unlock
    # -------------------------------------------------------------------------
    return run_unlock(
        locks       = locks,
        dry_run     = args.dry_run,
        force       = args.force,
        concurrency = args.concurrency,
    )


if __name__ == "__main__":
    sys.exit(main())
